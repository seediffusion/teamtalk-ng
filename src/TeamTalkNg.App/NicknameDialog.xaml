<Window x:Class="TeamTalkNg.App.NicknameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Nickname"
        Width="460"
        Height="200"
        MinWidth="420"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=NicknameBox}" Content="Nickname" />
      <TextBox x:Name="NicknameBox"
               Grid.Column="1"
               Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Nickname" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel nickname change" />
      <Button DockPanel.Dock="Right"
              Content="Save"
              Command="{Binding SaveCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Save nickname" />
    </DockPanel>
  </Grid>
</Window>

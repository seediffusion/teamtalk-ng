<Window x:Class="TeamTalkNg.App.ChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TeamTalkNg.App.Controls"
        Title="Create Channel"
        Width="520"
        Height="340"
        MinWidth="460"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="140" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=ParentPathBox}" Content="Parent channel" />
      <TextBox x:Name="ParentPathBox"
               Grid.Column="1"
               Text="{Binding ParentPath, Mode=OneWay}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Parent channel" />

      <Label Grid.Row="1" Target="{Binding ElementName=NameBox}" Content="Channel name" />
      <controls:NativeTextBox x:Name="NameBox"
                              Grid.Row="1"
                              Grid.Column="1"
                              Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                              TextBackground="{DynamicResource ControlBackgroundBrush}"
                              TextForeground="{DynamicResource TextBrush}"
                              AutomationProperties.Name="Channel name" />

      <Label Grid.Row="2" Target="{Binding ElementName=TopicBox}" Content="Topic" />
      <controls:NativeTextBox x:Name="TopicBox"
                              Grid.Row="2"
                              Grid.Column="1"
                              Text="{Binding Topic, UpdateSourceTrigger=PropertyChanged}"
                              TextBackground="{DynamicResource ControlBackgroundBrush}"
                              TextForeground="{DynamicResource TextBrush}"
                              AutomationProperties.Name="Channel topic" />

      <Label Grid.Row="3" Target="{Binding ElementName=PasswordBox}" Content="Password" />
      <PasswordBox x:Name="PasswordBox"
                   Grid.Row="3"
                   Grid.Column="1"
                   PasswordChanged="PasswordBox_OnPasswordChanged"
                   Background="{DynamicResource ControlBackgroundBrush}"
                   Foreground="{DynamicResource TextBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   AutomationProperties.Name="Channel password" />

      <Label Grid.Row="4" Target="{Binding ElementName=MaxUsersBox}" Content="Max users" />
      <controls:NativeTextBox x:Name="MaxUsersBox"
                              Grid.Row="4"
                              Grid.Column="1"
                              Text="{Binding MaxUsers, UpdateSourceTrigger=PropertyChanged}"
                              TextBackground="{DynamicResource ControlBackgroundBrush}"
                              TextForeground="{DynamicResource TextBrush}"
                              AutomationProperties.Name="Maximum users, zero for no limit" />

      <CheckBox Grid.Row="5"
                Grid.Column="1"
                Margin="0,8,0,0"
                IsChecked="{Binding IsPermanent}"
                Content="Permanent channel"
                AutomationProperties.Name="Permanent channel" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              MinWidth="96"
              Margin="8,0,0,0"
              IsCancel="True"
              AutomationProperties.Name="Cancel channel creation" />
      <Button DockPanel.Dock="Right"
              Content="Create"
              Command="{Binding CreateCommand}"
              MinWidth="96"
              IsDefault="True"
              AutomationProperties.Name="Create channel" />
    </DockPanel>
  </Grid>
</Window>

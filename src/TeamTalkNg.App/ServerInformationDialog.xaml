<Window x:Class="TeamTalkNg.App.ServerInformationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Information"
        Width="620"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="150" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=ServerNameBox}" Content="Server name" />
      <TextBox x:Name="ServerNameBox"
               Grid.Column="1"
               Text="{Binding ServerName}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Server name" />

      <Label Grid.Row="1" Target="{Binding ElementName=MotdBox}" Content="Message" />
      <TextBox x:Name="MotdBox"
               Grid.Row="1"
               Grid.Column="1"
               Text="{Binding MessageOfTheDay}"
               IsReadOnly="True"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Message of the day" />

      <Label Grid.Row="2" Target="{Binding ElementName=MaxUsersBox}" Content="Max users" />
      <TextBox x:Name="MaxUsersBox"
               Grid.Row="2"
               Grid.Column="1"
               Text="{Binding MaxUsers}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Maximum users" />

      <Label Grid.Row="3" Target="{Binding ElementName=TcpPortBox}" Content="TCP port" />
      <TextBox x:Name="TcpPortBox"
               Grid.Row="3"
               Grid.Column="1"
               Text="{Binding TcpPort}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="TCP port" />

      <Label Grid.Row="4" Target="{Binding ElementName=UdpPortBox}" Content="UDP port" />
      <TextBox x:Name="UdpPortBox"
               Grid.Row="4"
               Grid.Column="1"
               Text="{Binding UdpPort}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="UDP port" />

      <Label Grid.Row="5" Target="{Binding ElementName=TimeoutBox}" Content="User timeout" />
      <TextBox x:Name="TimeoutBox"
               Grid.Row="5"
               Grid.Column="1"
               Text="{Binding UserTimeout}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="User timeout" />

      <Label Grid.Row="6" Target="{Binding ElementName=ServerVersionBox}" Content="Server version" />
      <TextBox x:Name="ServerVersionBox"
               Grid.Row="6"
               Grid.Column="1"
               Text="{Binding ServerVersion}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Server version" />

      <Label Grid.Row="7" Target="{Binding ElementName=ProtocolVersionBox}" Content="Protocol version" />
      <TextBox x:Name="ProtocolVersionBox"
               Grid.Row="7"
               Grid.Column="1"
               Text="{Binding ProtocolVersion}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Protocol version" />

      <Label Grid.Row="8" Target="{Binding ElementName=LoginDelayBox}" Content="Login delay" />
      <TextBox x:Name="LoginDelayBox"
               Grid.Row="8"
               Grid.Column="1"
               Text="{Binding LoginDelay}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Login delay" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="OK"
              Command="{Binding CloseCommand}"
              IsDefault="True"
              IsCancel="True"
              MinWidth="96"
              AutomationProperties.Name="Close server information" />
    </DockPanel>
  </Grid>
</Window>

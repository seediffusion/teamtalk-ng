<Window x:Class="TeamTalkNg.App.PreferencesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TeamTalkNg.App.Controls"
        Title="Preferences"
        Width="620"
        Height="510"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <DockPanel Margin="16">
    <DockPanel DockPanel.Dock="Bottom"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel preferences" />
      <Button DockPanel.Dock="Right"
              Content="Save"
              Command="{Binding SaveCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Save preferences" />
    </DockPanel>

    <TabControl AutomationProperties.Name="Preferences sections"
                Background="{DynamicResource WindowBackgroundBrush}"
                Foreground="{DynamicResource TextBrush}">
      <TabItem Header="General">
        <Grid Margin="8,14,8,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Label Target="{Binding ElementName=ThemeBox}" Content="Theme" />
          <ComboBox x:Name="ThemeBox"
                    Grid.Column="1"
                    ItemsSource="{Binding Themes}"
                    SelectedValue="{Binding SelectedTheme}"
                    SelectedValuePath="Value"
                    DisplayMemberPath="Name"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    AutomationProperties.Name="Application theme">
            <ComboBox.ItemContainerStyle>
              <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
              </Style>
            </ComboBox.ItemContainerStyle>
          </ComboBox>
        </Grid>
      </TabItem>

      <TabItem Header="Audio">
        <Grid Margin="8,14,8,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Label Target="{Binding ElementName=InputDeviceBox}" Content="Microphone" />
          <ComboBox x:Name="InputDeviceBox"
                    Grid.Column="1"
                    ItemsSource="{Binding InputDevices}"
                    SelectedValue="{Binding SelectedInputDeviceId}"
                    SelectedValuePath="Id"
                    DisplayMemberPath="Name"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    AutomationProperties.Name="Microphone device">
            <ComboBox.ItemContainerStyle>
              <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
              </Style>
            </ComboBox.ItemContainerStyle>
          </ComboBox>

          <Label Grid.Row="1" Target="{Binding ElementName=OutputDeviceBox}" Content="Speaker" />
          <ComboBox x:Name="OutputDeviceBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    ItemsSource="{Binding OutputDevices}"
                    SelectedValue="{Binding SelectedOutputDeviceId}"
                    SelectedValuePath="Id"
                    DisplayMemberPath="Name"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    AutomationProperties.Name="Speaker device">
            <ComboBox.ItemContainerStyle>
              <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
              </Style>
            </ComboBox.ItemContainerStyle>
          </ComboBox>

          <Label Grid.Row="2" Target="{Binding ElementName=VoiceActivationLevelBox}" Content="Voice activation level" />
          <Slider x:Name="VoiceActivationLevelBox"
                  Grid.Row="2"
                  Grid.Column="1"
                  Minimum="0"
                  Maximum="100"
                  TickFrequency="5"
                  IsSnapToTickEnabled="True"
                  Value="{Binding VoiceActivationLevel}"
                  AutomationProperties.Name="Voice activation level" />

          <Button Grid.Row="3"
                  Grid.Column="1"
                  Content="Calibrate Voice Activation"
                  Command="{Binding CalibrateVoiceActivationCommand}"
                  MinWidth="170"
                  Margin="0,12,0,0"
                  HorizontalAlignment="Left"
                  AutomationProperties.Name="Calibrate voice activation" />

          <TextBlock Grid.Row="4"
                     Grid.Column="1"
                     Text="{Binding VoiceActivationCalibrationStatus}"
                     Margin="0,8,0,0"
                     Foreground="{DynamicResource MutedTextBrush}"
                     AutomationProperties.Name="Voice activation calibration status" />

          <CheckBox Grid.Row="5"
                    Grid.Column="1"
                    Content="Show input level meter"
                    IsChecked="{Binding ShowInputMeter}"
                    Margin="0,14,0,0"
                    AutomationProperties.Name="Show input level meter" />

          <CheckBox Grid.Row="6"
                    Grid.Column="1"
                    Content="Noise suppression"
                    IsChecked="{Binding EnableNoiseSuppression}"
                    Margin="0,14,0,0"
                    AutomationProperties.Name="Noise suppression" />

          <CheckBox Grid.Row="7"
                    Grid.Column="1"
                    Content="Echo cancellation"
                    IsChecked="{Binding EnableEchoCancellation}"
                    Margin="0,8,0,0"
                    AutomationProperties.Name="Echo cancellation" />

          <CheckBox Grid.Row="8"
                    Grid.Column="1"
                    Content="Automatic gain control"
                    IsChecked="{Binding EnableAutomaticGainControl}"
                    Margin="0,8,0,0"
                    AutomationProperties.Name="Automatic gain control" />

          <StackPanel Grid.Row="9"
                      Grid.Column="1"
                      Orientation="Horizontal"
                      Margin="0,14,0,0"
                      KeyboardNavigation.TabNavigation="Continue">
            <Button Content="Refresh Devices"
                    Command="{Binding RefreshAudioDevicesCommand}"
                    MinWidth="130"
                    AutomationProperties.Name="Refresh audio devices" />
            <TextBlock Text="{Binding AudioDeviceRefreshStatus}"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedTextBrush}"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Audio device refresh status" />
          </StackPanel>
        </Grid>
      </TabItem>

      <TabItem Header="Profile">
        <ScrollViewer Margin="8,14,8,8"
                      VerticalScrollBarVisibility="Auto"
                      AutomationProperties.Name="Profile preferences">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="200" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Label Target="{Binding ElementName=DefaultNicknameBox}" Content="Default nickname" />
            <controls:NativeTextBox x:Name="DefaultNicknameBox"
                                    Grid.Column="1"
                                    Text="{Binding DefaultNickname, UpdateSourceTrigger=PropertyChanged}"
                                    TextBackground="{DynamicResource ControlBackgroundBrush}"
                                    TextForeground="{DynamicResource TextBrush}"
                                    AutomationProperties.Name="Default nickname" />

            <CheckBox Grid.Row="1"
                      Grid.Column="1"
                      Content="Start as away"
                      IsChecked="{Binding IsAway}"
                      Margin="0,12,0,0"
                      AutomationProperties.Name="Start as away" />

            <Label Grid.Row="2"
                   Target="{Binding ElementName=StatusMessageBox}"
                   Content="Default status message"
                   Margin="0,12,0,0" />
            <controls:NativeTextBox x:Name="StatusMessageBox"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    MinHeight="72"
                                    Margin="0,12,0,0"
                                    AcceptsReturn="True"
                                    Text="{Binding StatusMessage, UpdateSourceTrigger=PropertyChanged}"
                                    TextBackground="{DynamicResource ControlBackgroundBrush}"
                                    TextForeground="{DynamicResource TextBrush}"
                                    AutomationProperties.Name="Default status message" />

            <TextBlock Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Text="Inactivity"
                       FontWeight="SemiBold"
                       Margin="0,18,0,0"
                       AutomationProperties.Name="Inactivity settings" />

            <Label Grid.Row="4"
                   Target="{Binding ElementName=InactivityTimeoutBox}"
                   Content="Set away after seconds"
                   Margin="0,10,0,0" />
            <controls:NativeTextBox x:Name="InactivityTimeoutBox"
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Text="{Binding InactivityTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,10,0,0"
                                    TextBackground="{DynamicResource ControlBackgroundBrush}"
                                    TextForeground="{DynamicResource TextBrush}"
                                    AutomationProperties.Name="Set away after inactivity seconds"
                                    AutomationProperties.HelpText="Use 0 to never set away automatically." />

            <CheckBox Grid.Row="5"
                      Grid.Column="1"
                      Content="Disable voice activation during inactivity"
                      IsChecked="{Binding DisableVoiceActivationDuringInactivity}"
                      Margin="0,12,0,0"
                      AutomationProperties.Name="Disable voice activation during inactivity" />

            <Label Grid.Row="6"
                   Target="{Binding ElementName=InactivityStatusMessageBox}"
                   Content="Status during inactivity"
                   Margin="0,12,0,0" />
            <controls:NativeTextBox x:Name="InactivityStatusMessageBox"
                                    Grid.Row="6"
                                    Grid.Column="1"
                                    MinHeight="72"
                                    Margin="0,12,0,0"
                                    AcceptsReturn="True"
                                    Text="{Binding InactivityStatusMessage, UpdateSourceTrigger=PropertyChanged}"
                                    TextBackground="{DynamicResource ControlBackgroundBrush}"
                                    TextForeground="{DynamicResource TextBrush}"
                                    AutomationProperties.Name="Status during inactivity" />
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Screen reader">
        <ScrollViewer Margin="8,14,8,8"
                      VerticalScrollBarVisibility="Auto"
                      AutomationProperties.Name="Screen reader preferences">
          <StackPanel>
            <CheckBox Content="Announce channel messages"
                      IsChecked="{Binding AnnounceChannelMessages}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Announce channel messages" />
            <CheckBox Content="Announce direct messages"
                      IsChecked="{Binding AnnounceDirectMessages}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Announce direct messages" />
            <CheckBox Content="Announce users joining and leaving"
                      IsChecked="{Binding AnnounceUserJoinLeave}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Announce users joining and leaving" />
            <CheckBox Content="Announce channel tree selection changes"
                      IsChecked="{Binding AnnounceSelectionChanges}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Announce channel tree selection changes" />
            <CheckBox Content="Send announcements to braille when available"
                      IsChecked="{Binding SendAnnouncementsToBraille}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Send announcements to braille when available" />
            <CheckBox Content="Interrupt speech for important announcements"
                      IsChecked="{Binding InterruptImportantAnnouncements}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Interrupt speech for important announcements" />
            <CheckBox Content="Show announcements in the status bar"
                      IsChecked="{Binding ShowAnnouncementsInStatusBar}"
                      Margin="0,0,0,10"
                      AutomationProperties.Name="Show announcements in the status bar" />
            <CheckBox Content="Show chat and direct message announcements in the status bar"
                      IsChecked="{Binding ShowMessageAnnouncementsInStatusBar}"
                      Margin="0,0,0,16"
                      AutomationProperties.Name="Show chat and direct message announcements in the status bar" />
            <CheckBox Content="Hide direct message text in chat history"
                      IsChecked="{Binding HideDirectMessageTextInChatHistory}"
                      Margin="0,0,0,16"
                      AutomationProperties.Name="Hide direct message text in chat history" />

            <TextBlock Text="Announcement templates"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"
                       AutomationProperties.Name="Announcement templates" />
            <ListView ItemsSource="{Binding AnnouncementTemplates}"
                      MinHeight="170"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      KeyboardNavigation.TabNavigation="Continue"
                      AutomationProperties.Name="Announcement templates">
              <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
              </ListView.ItemContainerStyle>
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Enabled" Width="76">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <CheckBox IsChecked="{Binding IsEnabled}"
                                  HorizontalAlignment="Center"
                                  AutomationProperties.Name="{Binding Name, StringFormat={}{0} screen reader announcement enabled}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Event" DisplayMemberBinding="{Binding Name}" Width="120" />
                  <GridViewColumn Header="Template" Width="240">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <controls:NativeTextBox Text="{Binding Template, UpdateSourceTrigger=PropertyChanged}"
                                                MinWidth="210"
                                                TextBackground="{DynamicResource ControlBackgroundBrush}"
                                                TextForeground="{DynamicResource TextBrush}"
                                                AutomationProperties.Name="{Binding Name, StringFormat={}{0} announcement template}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Placeholders" DisplayMemberBinding="{Binding PlaceholderSummary}" Width="150" />
                </GridView>
              </ListView.View>
            </ListView>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Sounds">
        <Grid Margin="8,14,8,8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <CheckBox Grid.Column="1"
                    Content="Play sound events"
                    IsChecked="{Binding PlaySoundEvents}"
                    AutomationProperties.Name="Play sound events" />

          <Label Grid.Row="1"
                 Target="{Binding ElementName=SoundPackBox}"
                 Content="Sound pack"
                 Margin="0,12,0,0" />
          <ComboBox x:Name="SoundPackBox"
                    Grid.Row="1"
                    Grid.Column="1"
                    ItemsSource="{Binding SoundPacks}"
                    SelectedValue="{Binding SelectedSoundPack}"
                    SelectedValuePath="Id"
                    DisplayMemberPath="Name"
                    Margin="0,12,0,0"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    AutomationProperties.Name="Sound pack">
            <ComboBox.ItemContainerStyle>
              <Style TargetType="{x:Type ComboBoxItem}">
                <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
              </Style>
            </ComboBox.ItemContainerStyle>
          </ComboBox>

          <Label Grid.Row="2"
                 Target="{Binding ElementName=SoundEventVolumeSlider}"
                 Content="Sound event volume"
                 Margin="0,12,0,0" />
          <Slider x:Name="SoundEventVolumeSlider"
                  Grid.Row="2"
                  Grid.Column="1"
                  Minimum="0"
                  Maximum="100"
                  TickFrequency="5"
                  IsSnapToTickEnabled="True"
                  Value="{Binding SoundEventVolume}"
                  Margin="0,12,0,0"
                  AutomationProperties.Name="Sound event volume" />

          <Grid Grid.Row="3"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Default uses WAV files placed directly in the Sounds folder. Named sound packs are folders inside Sounds."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MutedTextBrush}"
                       AutomationProperties.Name="Sound pack folder help" />

            <ListView Grid.Row="1"
                      ItemsSource="{Binding SoundEvents}"
                      Margin="0,10,0,0"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      AutomationProperties.Name="Sound events">
              <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
              </ListView.ItemContainerStyle>
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Enabled" Width="88">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <CheckBox IsChecked="{Binding IsEnabled}"
                                  HorizontalAlignment="Center"
                                  AutomationProperties.Name="{Binding Name}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Event" DisplayMemberBinding="{Binding Name}" Width="210" />
                  <GridViewColumn Header="Sound Event File" DisplayMemberBinding="{Binding FileName}" Width="165" />
                  <GridViewColumn Header="Test" Width="80">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <Button Content="Play"
                                Command="{Binding PlayCommand}"
                                MinWidth="58"
                                AutomationProperties.Name="{Binding Name, StringFormat=Play {0} sound}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>

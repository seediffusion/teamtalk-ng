<Window x:Class="TeamTalkNg.App.BannedUsersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Banned Users"
        Width="820"
        Height="520"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ListView ItemsSource="{Binding BannedUsers}"
              SelectedItem="{Binding SelectedBan, Mode=TwoWay}"
              Background="{DynamicResource ControlBackgroundBrush}"
              Foreground="{DynamicResource TextBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              AutomationProperties.Name="Banned users">
      <ListView.ItemContainerStyle>
        <Style TargetType="{x:Type ListViewItem}">
          <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.View>
        <GridView>
          <GridViewColumn Header="IP address" DisplayMemberBinding="{Binding IpAddress}" Width="130" />
          <GridViewColumn Header="Username" DisplayMemberBinding="{Binding Username}" Width="120" />
          <GridViewColumn Header="Nickname" DisplayMemberBinding="{Binding Nickname}" Width="150" />
          <GridViewColumn Header="Channel" DisplayMemberBinding="{Binding ChannelPath}" Width="130" />
          <GridViewColumn Header="Type" DisplayMemberBinding="{Binding BanTypes}" Width="130" />
          <GridViewColumn Header="Owner" DisplayMemberBinding="{Binding Owner}" Width="120" />
          <GridViewColumn Header="Time" DisplayMemberBinding="{Binding BanTime}" Width="150" />
        </GridView>
      </ListView.View>
    </ListView>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Close"
              Command="{Binding CloseCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Close banned users" />
      <Button DockPanel.Dock="Right"
              Content="Remove Ban"
              Command="{Binding RemoveBanCommand}"
              IsDefault="True"
              MinWidth="120"
              AutomationProperties.Name="Remove selected ban" />
    </DockPanel>
  </Grid>
</Window>

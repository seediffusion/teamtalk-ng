<Window x:Class="TeamTalkNg.App.UserInformationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Information"
        Width="520"
        Height="320"
        MinWidth="460"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=NicknameBox}" Content="Nickname" />
      <TextBox x:Name="NicknameBox"
               Grid.Column="1"
               Text="{Binding Nickname}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Nickname" />

      <Label Grid.Row="1" Target="{Binding ElementName=UsernameBox}" Content="Username" />
      <TextBox x:Name="UsernameBox"
               Grid.Row="1"
               Grid.Column="1"
               Text="{Binding Username}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Username" />

      <Label Grid.Row="2" Target="{Binding ElementName=ChannelBox}" Content="Channel" />
      <TextBox x:Name="ChannelBox"
               Grid.Row="2"
               Grid.Column="1"
               Text="{Binding Channel}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Current channel" />

      <Label Grid.Row="3" Target="{Binding ElementName=StatusBox}" Content="Status" />
      <TextBox x:Name="StatusBox"
               Grid.Row="3"
               Grid.Column="1"
               Text="{Binding Status}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="User status" />

      <Label Grid.Row="4" Target="{Binding ElementName=OperatorBox}" Content="Operator" />
      <TextBox x:Name="OperatorBox"
               Grid.Row="4"
               Grid.Column="1"
               Text="{Binding Operator}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Channel operator" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="OK"
              Command="{Binding CloseCommand}"
              IsDefault="True"
              IsCancel="True"
              MinWidth="96"
              AutomationProperties.Name="Close user information" />
    </DockPanel>
  </Grid>
</Window>

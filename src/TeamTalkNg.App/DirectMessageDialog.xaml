<Window x:Class="TeamTalkNg.App.DirectMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Direct Message"
        Width="520"
        Height="440"
        MinWidth="440"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=RecipientBox}" Content="To" />
      <TextBox x:Name="RecipientBox"
               Grid.Column="1"
               Text="{Binding RecipientName, Mode=OneWay}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Direct message recipient" />

      <Label Grid.Row="1"
             Target="{Binding ElementName=ConversationList}"
             Content="History"
             Margin="0,12,0,0" />
      <ListView x:Name="ConversationList"
                Grid.Row="1"
                Grid.Column="1"
                ItemsSource="{Binding Conversation}"
                Margin="0,12,0,0"
                Background="{DynamicResource ControlBackgroundBrush}"
                Foreground="{DynamicResource TextBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                AutomationProperties.Name="{Binding ConversationName}">
        <ListView.ItemContainerStyle>
          <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="AutomationProperties.Name" Value="{Binding FullAccessibleName}" />
            <Setter Property="AutomationProperties.HelpText" Value="{Binding FullAccessibleName}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding FullDisplayText}"
                       TextWrapping="Wrap"
                       TextTrimming="None"
                       Foreground="{DynamicResource TextBrush}" />
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>

      <Label Grid.Row="2"
             Target="{Binding ElementName=MessageBox}"
             Content="Message"
             Margin="0,12,0,0" />
      <TextBox x:Name="MessageBox"
               Grid.Row="2"
               Grid.Column="1"
               Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}"
               AcceptsReturn="True"
               Margin="0,12,0,0"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Direct message text" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel direct message" />
      <Button DockPanel.Dock="Right"
              Content="Send"
              Command="{Binding SendCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Send direct message" />
    </DockPanel>
  </Grid>
</Window>

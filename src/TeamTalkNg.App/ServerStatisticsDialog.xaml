<Window x:Class="TeamTalkNg.App.ServerStatisticsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Statistics"
        Width="620"
        Height="620"
        MinWidth="520"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="180" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Target="{Binding ElementName=UptimeBox}" Content="Uptime" />
        <TextBox x:Name="UptimeBox"
                 Grid.Column="1"
                 Text="{Binding Uptime, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Server uptime" />

        <Label Grid.Row="1" Target="{Binding ElementName=UsersServedBox}" Content="Users served" />
        <TextBox x:Name="UsersServedBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Text="{Binding UsersServed, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Users served" />

        <Label Grid.Row="2" Target="{Binding ElementName=PeakUsersBox}" Content="Peak users" />
        <TextBox x:Name="PeakUsersBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Text="{Binding PeakUsers, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Peak users" />

        <Label Grid.Row="3" Target="{Binding ElementName=TotalSentBox}" Content="Total sent" />
        <TextBox x:Name="TotalSentBox"
                 Grid.Row="3"
                 Grid.Column="1"
                 Text="{Binding TotalSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Total bytes sent" />

        <Label Grid.Row="4" Target="{Binding ElementName=TotalReceivedBox}" Content="Total received" />
        <TextBox x:Name="TotalReceivedBox"
                 Grid.Row="4"
                 Grid.Column="1"
                 Text="{Binding TotalReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Total bytes received" />

        <Label Grid.Row="5" Target="{Binding ElementName=VoiceSentBox}" Content="Voice sent" />
        <TextBox x:Name="VoiceSentBox"
                 Grid.Row="5"
                 Grid.Column="1"
                 Text="{Binding VoiceSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Voice bytes sent" />

        <Label Grid.Row="6" Target="{Binding ElementName=VoiceReceivedBox}" Content="Voice received" />
        <TextBox x:Name="VoiceReceivedBox"
                 Grid.Row="6"
                 Grid.Column="1"
                 Text="{Binding VoiceReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Voice bytes received" />

        <Label Grid.Row="7" Target="{Binding ElementName=VideoSentBox}" Content="Video sent" />
        <TextBox x:Name="VideoSentBox"
                 Grid.Row="7"
                 Grid.Column="1"
                 Text="{Binding VideoSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Video capture bytes sent" />

        <Label Grid.Row="8" Target="{Binding ElementName=VideoReceivedBox}" Content="Video received" />
        <TextBox x:Name="VideoReceivedBox"
                 Grid.Row="8"
                 Grid.Column="1"
                 Text="{Binding VideoReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Video capture bytes received" />

        <Label Grid.Row="9" Target="{Binding ElementName=MediaFileSentBox}" Content="Media file sent" />
        <TextBox x:Name="MediaFileSentBox"
                 Grid.Row="9"
                 Grid.Column="1"
                 Text="{Binding MediaFileSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Media file bytes sent" />

        <Label Grid.Row="10" Target="{Binding ElementName=MediaFileReceivedBox}" Content="Media file received" />
        <TextBox x:Name="MediaFileReceivedBox"
                 Grid.Row="10"
                 Grid.Column="1"
                 Text="{Binding MediaFileReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Media file bytes received" />

        <Label Grid.Row="11" Target="{Binding ElementName=DesktopSentBox}" Content="Desktop sent" />
        <TextBox x:Name="DesktopSentBox"
                 Grid.Row="11"
                 Grid.Column="1"
                 Text="{Binding DesktopSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Desktop bytes sent" />

        <Label Grid.Row="12" Target="{Binding ElementName=DesktopReceivedBox}" Content="Desktop received" />
        <TextBox x:Name="DesktopReceivedBox"
                 Grid.Row="12"
                 Grid.Column="1"
                 Text="{Binding DesktopReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Desktop bytes received" />

        <Label Grid.Row="13" Target="{Binding ElementName=FileSentBox}" Content="Files sent" />
        <TextBox x:Name="FileSentBox"
                 Grid.Row="13"
                 Grid.Column="1"
                 Text="{Binding FileSent, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="File transfer bytes sent" />

        <Label Grid.Row="14" Target="{Binding ElementName=FileReceivedBox}" Content="Files received" />
        <TextBox x:Name="FileReceivedBox"
                 Grid.Row="14"
                 Grid.Column="1"
                 Text="{Binding FileReceived, Mode=OneWay}"
                 IsReadOnly="True"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="File transfer bytes received" />
      </Grid>
    </ScrollViewer>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="OK"
              Command="{Binding CloseCommand}"
              IsDefault="True"
              IsCancel="True"
              MinWidth="96"
              AutomationProperties.Name="Close server statistics" />
    </DockPanel>
  </Grid>
</Window>

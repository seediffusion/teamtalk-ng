<Window x:Class="TeamTalkNg.App.UserAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New User Account"
        Width="720"
        Height="620"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  KeyboardNavigation.TabNavigation="Continue">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="170" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="UsernameLabel" Text="Username" VerticalAlignment="Center" Margin="0,0,12,10" />
        <TextBox Grid.Column="1"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.LabeledBy="{Binding ElementName=UsernameLabel}"
                 AutomationProperties.Name="Username" />

        <TextBlock x:Name="PasswordLabel" Grid.Row="1" Text="Password" VerticalAlignment="Center" Margin="0,0,12,10" />
        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.LabeledBy="{Binding ElementName=PasswordLabel}"
                 AutomationProperties.Name="Password" />

        <TextBlock x:Name="UserTypeLabel" Grid.Row="2" Text="Account type" VerticalAlignment="Center" Margin="0,0,12,10" />
        <ComboBox Grid.Row="2"
                  Grid.Column="1"
                  ItemsSource="{Binding UserTypes}"
                  SelectedItem="{Binding SelectedUserType, Mode=TwoWay}"
                  Margin="0,0,0,10"
                  Background="{DynamicResource ControlBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  AutomationProperties.LabeledBy="{Binding ElementName=UserTypeLabel}"
                  AutomationProperties.Name="Account type" />

        <TextBlock x:Name="InitialChannelLabel" Grid.Row="3" Text="Initial channel" VerticalAlignment="Center" Margin="0,0,12,10" />
        <TextBox Grid.Row="3"
                 Grid.Column="1"
                 Text="{Binding InitialChannel, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.LabeledBy="{Binding ElementName=InitialChannelLabel}"
                 AutomationProperties.Name="Initial channel" />

        <TextBlock x:Name="BitrateLimitLabel" Grid.Row="4" Text="Audio bitrate limit" VerticalAlignment="Center" Margin="0,0,12,10" />
        <TextBox Grid.Row="4"
                 Grid.Column="1"
                 Text="{Binding AudioCodecBitrateLimit, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,10"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.LabeledBy="{Binding ElementName=BitrateLimitLabel}"
                 AutomationProperties.Name="Audio bitrate limit" />

        <TextBlock x:Name="NoteLabel" Grid.Row="5" Text="Note" VerticalAlignment="Top" Margin="0,0,12,10" />
        <TextBox Grid.Row="5"
                 Grid.Column="1"
                 Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                 MinHeight="72"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.LabeledBy="{Binding ElementName=NoteLabel}"
                 AutomationProperties.Name="Note" />

        <TextBlock Grid.Row="6"
                   Grid.ColumnSpan="2"
                   Text="Rights"
                   Margin="0,6,0,8"
                   FontWeight="SemiBold"
                   AutomationProperties.Name="Rights" />

        <ItemsControl Grid.Row="7"
                      Grid.ColumnSpan="2"
                      ItemsSource="{Binding Rights}"
                      KeyboardNavigation.TabNavigation="Continue">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="2" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <CheckBox Content="{Binding Name}"
                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                        Margin="0,0,16,8"
                        Foreground="{DynamicResource TextBrush}"
                        AutomationProperties.Name="{Binding AccessibleName}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </ScrollViewer>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel new user account" />
      <Button DockPanel.Dock="Right"
              Content="Create"
              Command="{Binding CreateCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Create user account" />
    </DockPanel>
  </Grid>
</Window>

<Window x:Class="TeamTalkNg.App.ConnectionTargetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TeamTalkNg.App.Controls"
        Title="Open Connection Target"
        Width="640"
        Height="250"
        MinWidth="560"
        MinHeight="230"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <DockPanel Margin="16">
    <DockPanel DockPanel.Dock="Bottom"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel open connection target" />
      <Button DockPanel.Dock="Right"
              Content="Connect"
              Command="{Binding ConnectCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Connect using connection target" />
    </DockPanel>

    <StackPanel>
      <Label Target="{Binding ElementName=TargetBox}" Content="TeamTalk URL or .tt file" />
      <DockPanel>
        <Button DockPanel.Dock="Right"
                Content="Browse"
                Click="BrowseButton_OnClick"
                MinWidth="96"
                Margin="8,0,0,0"
                AutomationProperties.Name="Browse for TeamTalk connection file" />
        <controls:NativeTextBox x:Name="TargetBox"
                                Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                                MinHeight="34"
                                TextBackground="{DynamicResource ControlBackgroundBrush}"
                                TextForeground="{DynamicResource TextBrush}"
                                AutomationProperties.Name="TeamTalk URL or .tt file path" />
      </DockPanel>
      <TextBlock Margin="0,10,0,0"
                 Foreground="{DynamicResource MutedTextBrush}"
                 Text="Examples: tt://example.org?tcpport=10333 or C:\Servers\myserver.tt" />
    </StackPanel>
  </DockPanel>
</Window>

<Window x:Class="TeamTalkNg.App.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to Server"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240" MinWidth="220" />
      <ColumnDefinition Width="16" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <GroupBox Header="Saved servers"
              Foreground="{DynamicResource TextBrush}"
              BorderBrush="{DynamicResource BorderBrush}">
      <ListBox ItemsSource="{Binding Profiles}"
               SelectedItem="{Binding SelectedProfile}"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Saved servers">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="2">
              <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource MutedTextBrush}" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </GroupBox>

    <GroupBox Grid.Column="2"
              Header="Server details"
              Foreground="{DynamicResource TextBrush}"
              BorderBrush="{DynamicResource BorderBrush}">
      <Grid Margin="10">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Target="{Binding ElementName=DisplayNameBox}" Content="Entry name" />
        <TextBox x:Name="DisplayNameBox"
                 Grid.Column="1"
                 Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Entry name" />

        <Label Grid.Row="1" Target="{Binding ElementName=HostBox}" Content="Host address" />
        <TextBox x:Name="HostBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Host address" />

        <Label Grid.Row="2" Target="{Binding ElementName=TcpPortBox}" Content="TCP port" />
        <TextBox x:Name="TcpPortBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="TCP port" />

        <Label Grid.Row="3" Target="{Binding ElementName=UdpPortBox}" Content="UDP port" />
        <TextBox x:Name="UdpPortBox"
                 Grid.Row="3"
                 Grid.Column="1"
                 Text="{Binding UdpPort, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="UDP port" />

        <CheckBox Grid.Row="4"
                  Grid.Column="1"
                  Margin="0,8,0,8"
                  IsChecked="{Binding IsEncrypted}"
                  Content="Encrypted server"
                  AutomationProperties.Name="Encrypted server" />

        <Label Grid.Row="5" Target="{Binding ElementName=UsernameBox}" Content="Username" />
        <TextBox x:Name="UsernameBox"
                 Grid.Row="5"
                 Grid.Column="1"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Username" />

        <Label Grid.Row="6" Target="{Binding ElementName=PasswordBox}" Content="Password" />
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="6"
                     Grid.Column="1"
                     PasswordChanged="PasswordBox_OnPasswordChanged"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     AutomationProperties.Name="Password" />

        <Label Grid.Row="7" Target="{Binding ElementName=NicknameBox}" Content="Nickname" />
        <TextBox x:Name="NicknameBox"
                 Grid.Row="7"
                 Grid.Column="1"
                 Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Nickname" />

        <Label Grid.Row="8" Target="{Binding ElementName=ChannelBox}" Content="Channel" />
        <TextBox x:Name="ChannelBox"
                 Grid.Row="8"
                 Grid.Column="1"
                 Text="{Binding ChannelPath, UpdateSourceTrigger=PropertyChanged}"
                 Background="{DynamicResource ControlBackgroundBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 AutomationProperties.Name="Channel to join after login" />

        <Label Grid.Row="9" Target="{Binding ElementName=ChannelPasswordBox}" Content="Channel password" />
        <PasswordBox x:Name="ChannelPasswordBox"
                     Grid.Row="9"
                     Grid.Column="1"
                     PasswordChanged="ChannelPasswordBox_OnPasswordChanged"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     AutomationProperties.Name="Channel password" />
      </Grid>
    </GroupBox>

    <DockPanel Grid.Row="1"
               Grid.ColumnSpan="3"
               Margin="0,16,0,0"
               LastChildFill="False">
      <TextBlock DockPanel.Dock="Left"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource MutedTextBrush}"
                 Text="Passwords are used for this connection only and are not saved yet." />
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              MinWidth="96"
              Margin="8,0,0,0"
              IsCancel="True"
              AutomationProperties.Name="Cancel connect dialog" />
      <Button DockPanel.Dock="Right"
              Content="Connect"
              Command="{Binding ConnectCommand}"
              MinWidth="96"
              IsDefault="True"
              AutomationProperties.Name="Connect to selected server" />
    </DockPanel>
  </Grid>
</Window>

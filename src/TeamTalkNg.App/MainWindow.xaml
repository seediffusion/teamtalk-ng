<Window x:Class="TeamTalkNg.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TeamTalkNg.App.Controls"
        xmlns:vm="clr-namespace:TeamTalkNg.App.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="600"
        Topmost="{Binding IsAlwaysOnTop}"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Window.InputBindings>
    <KeyBinding Key="F2" Command="{Binding ConnectCommand}" />
    <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenConnectionTargetCommand}" />
    <KeyBinding Modifiers="Control+Shift" Key="A" Command="{Binding ToggleVoiceActivationCommand}" />
    <KeyBinding Modifiers="Control+Shift" Key="M" Command="{Binding ToggleSelectedUserMuteCommand}" />
  </Window.InputBindings>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <HierarchicalDataTemplate DataType="{x:Type vm:ChannelTreeItemViewModel}" ItemsSource="{Binding Children}">
      <Grid ToolTip="{Binding AccessibleName}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="22" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <controls:PresentationTextBlock Text="{Binding VisualIndicator}"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,4,0" />
        <controls:PresentationTextBlock Grid.Column="1"
                                        Text="{Binding DisplayText}"
                                        TextTrimming="None"
                                        TextWrapping="NoWrap" />
      </Grid>
    </HierarchicalDataTemplate>
  </Window.Resources>

  <DockPanel>
    <Menu DockPanel.Dock="Top"
          Focusable="False"
          IsTabStop="False"
          KeyboardNavigation.TabNavigation="None"
          Background="{DynamicResource PanelBackgroundBrush}"
          Foreground="{DynamicResource TextBrush}">
      <MenuItem Header="_Client">
        <MenuItem Header="_Connect" Command="{Binding ConnectCommand}" InputGestureText="F2" />
        <MenuItem Header="_Open Connection Target" Command="{Binding OpenConnectionTargetCommand}" InputGestureText="Ctrl+O" />
        <MenuItem Header="_Disconnect" Command="{Binding DisconnectCommand}" />
        <Separator />
        <MenuItem Header="_Refresh Audio Devices" Command="{Binding RefreshAudioDevicesCommand}" />
        <MenuItem Header="Show _Input Meter"
                  Command="{Binding ToggleInputMeterCommand}"
                  IsCheckable="True"
                  IsChecked="{Binding IsInputMeterVisible, Mode=OneWay}" />
        <Separator />
        <MenuItem Header="_Preferences" Command="{Binding PreferencesCommand}" />
        <Separator />
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Server">
        <MenuItem Header="Server _Information" Command="{Binding ServerInformationCommand}" />
        <MenuItem Header="Server _Statistics" Command="{Binding ServerStatisticsCommand}" />
        <MenuItem Header="_Banned Users" Command="{Binding BannedUsersCommand}" />
        <MenuItem Header="_User Accounts" Command="{Binding UserAccountsCommand}" />
        <Separator />
        <MenuItem Header="_Save Configuration" Command="{Binding SaveServerConfigurationCommand}" />
      </MenuItem>
      <MenuItem Header="_Me">
        <MenuItem Header="Change _Nickname" Command="{Binding ChangeNicknameCommand}" />
        <MenuItem Header="Set _Status" Command="{Binding SetStatusCommand}" />
        <Separator />
        <MenuItem Header="Enable _Push To Talk"
                  Command="{Binding TogglePushToTalkCommand}"
                  IsCheckable="True"
                  IsChecked="{Binding IsPushToTalkEnabled, Mode=OneWay}" />
        <MenuItem Header="Enable _Voice Activation"
                  Command="{Binding ToggleVoiceActivationCommand}"
                  InputGestureText="Ctrl+Shift+A"
                  IsCheckable="True"
                  IsChecked="{Binding IsVoiceActivationEnabled, Mode=OneWay}" />
        <Separator />
        <MenuItem Header="Start _Video" Command="{Binding ToggleVideoCaptureCommand}" />
        <MenuItem Header="Refresh _Cameras" Command="{Binding RefreshVideoDevicesCommand}" />
        <Separator />
        <MenuItem Header="Share _Desktop" Command="{Binding ShareDesktopCommand}" />
        <MenuItem Header="Share Active _Window" Command="{Binding ShareActiveWindowCommand}" />
        <MenuItem Header="Stop Desktop _Sharing" Command="{Binding StopDesktopShareCommand}" />
      </MenuItem>
      <MenuItem Header="_Channels">
        <MenuItem Header="_Join Selected Channel" Command="{Binding JoinSelectedChannelCommand}" />
        <MenuItem Header="Channel _Information" Command="{Binding ChannelInformationCommand}" />
        <MenuItem Header="Edit Channel _Topic" Command="{Binding EditChannelTopicCommand}" />
        <Separator />
        <MenuItem Header="_Create Channel" Command="{Binding CreateChannelCommand}" />
        <MenuItem Header="_Delete Selected Channel" Command="{Binding DeleteSelectedChannelCommand}" />
        <Separator />
        <MenuItem Header="_Upload File" Command="{Binding UploadFileCommand}" />
        <MenuItem Header="_Download Selected File" Command="{Binding DownloadFileCommand}" />
        <MenuItem Header="_Delete Selected File" Command="{Binding DeleteFileCommand}" />
        <Separator />
        <MenuItem Header="_Cancel Selected Transfer" Command="{Binding CancelTransferCommand}" />
        <Separator />
        <MenuItem Header="_Refresh File List" Command="{Binding RefreshFilesCommand}" />
      </MenuItem>
      <MenuItem Header="_Users">
        <MenuItem Header="User _Information" Command="{Binding UserInformationCommand}" />
        <MenuItem Header="User _Audio Settings" Command="{Binding UserAudioSettingsCommand}" />
        <MenuItem Header="Toggle Local _Mute" Command="{Binding ToggleSelectedUserMuteCommand}" InputGestureText="Ctrl+Shift+M" />
        <MenuItem Header="Send _Direct Message" Command="{Binding SendDirectMessageCommand}" />
        <Separator />
        <MenuItem Header="_Move To Channel" Command="{Binding MoveUserCommand}" />
        <MenuItem Header="_Kick From Channel" Command="{Binding KickUserFromChannelCommand}" />
        <MenuItem Header="Kick From _Server" Command="{Binding KickUserFromServerCommand}" />
        <MenuItem Header="_Ban From Server" Command="{Binding BanUserFromServerCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About TeamTalk NG" Command="{Binding AboutCommand}" />
      </MenuItem>
    </Menu>

    <ToolBarTray DockPanel.Dock="Top"
                 Focusable="False"
                 KeyboardNavigation.TabNavigation="Continue"
                 Background="{DynamicResource PanelBackgroundBrush}">
      <ToolBar x:Name="MainToolBar"
               Background="{DynamicResource PanelBackgroundBrush}"
               Focusable="True"
               IsTabStop="True"
               GotKeyboardFocus="MainToolBar_OnGotKeyboardFocus"
               PreviewKeyDown="MainToolBar_OnPreviewKeyDown"
               KeyboardNavigation.TabNavigation="Continue"
               KeyboardNavigation.ControlTabNavigation="Continue"
               KeyboardNavigation.DirectionalNavigation="Contained"
               AutomationProperties.Name="Toolbar">
        <Button x:Name="ConnectToolBarButton"
                Tag="ToolbarButton"
                Command="{Binding ConnectCommand}"
                Focusable="True"
                IsTabStop="False"
                AutomationProperties.Name="Connect to server">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Connect" />
          </StackPanel>
        </Button>
        <ToggleButton Command="{Binding TogglePushToTalkCommand}"
                      IsChecked="{Binding IsPushToTalkEnabled, Mode=OneWay}"
                      Tag="ToolbarButton"
                      Focusable="True"
                      IsTabStop="False"
                      AutomationProperties.Name="Push to talk">
          <TextBlock Text="Push To Talk" />
        </ToggleButton>
        <ToggleButton Command="{Binding ToggleVoiceActivationCommand}"
                      IsChecked="{Binding IsVoiceActivationEnabled, Mode=OneWay}"
                      Tag="ToolbarButton"
                      Focusable="True"
                      IsTabStop="False"
                      AutomationProperties.Name="Voice activation">
          <TextBlock Text="Voice Activation" />
        </ToggleButton>
        <Separator />
        <ToggleButton Command="{Binding ToggleVideoCaptureCommand}"
                      IsChecked="{Binding IsVideoCaptureActive, Mode=OneWay}"
                      Tag="ToolbarButton"
                      Focusable="True"
                      IsTabStop="False"
                      AutomationProperties.Name="Video transmission">
          <TextBlock Text="Video" />
        </ToggleButton>
        <ToggleButton Command="{Binding ShareDesktopCommand}"
                      IsChecked="{Binding IsDesktopSharingActive, Mode=OneWay}"
                      Tag="ToolbarButton"
                      Focusable="True"
                      IsTabStop="False"
                      AutomationProperties.Name="Share desktop">
          <TextBlock Text="Share Desktop" />
        </ToggleButton>
        <Button Command="{Binding StopDesktopShareCommand}"
                Tag="ToolbarButton"
                Focusable="True"
                IsTabStop="False"
                AutomationProperties.Name="Stop desktop sharing">
          <TextBlock Text="Stop Share" />
        </Button>
        <Separator />
        <Button Command="{Binding SimulateUserJoinedCommand}"
                Tag="ToolbarButton"
                Focusable="True"
                IsTabStop="False"
                AutomationProperties.Name="Simulate a user joining the channel">
          <TextBlock Text="Simulate Join" />
        </Button>
      </ToolBar>
    </ToolBarTray>

    <StatusBar DockPanel.Dock="Bottom"
               Background="{DynamicResource PanelBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}">
      <StatusBarItem>
        <TextBlock Text="{Binding ConnectionStatusText}" />
      </StatusBarItem>
      <Separator />
      <StatusBarItem>
        <TextBlock Text="{Binding LiveAnnouncement}" />
      </StatusBarItem>
    </StatusBar>

    <Grid Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" MinWidth="260" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" MinWidth="420" />
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="Channels and users"
                  Foreground="{DynamicResource TextBrush}"
                  BorderBrush="{DynamicResource BorderBrush}">
          <TreeView x:Name="ChannelsTree"
                    ItemsSource="{Binding Channels}"
                    SelectedItemChanged="ChannelsTree_OnSelectedItemChanged"
                    KeyDown="ChannelsTree_OnKeyDown"
                    MouseDoubleClick="ChannelsTree_OnMouseDoubleClick"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    AutomationProperties.Name="Channels and users">
            <TreeView.ItemContainerStyle>
              <Style TargetType="{x:Type TreeViewItem}">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                <Setter Property="AutomationProperties.HelpText" Value="{Binding AccessibleHelpText}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="KeyboardNavigation.TabNavigation" Value="Continue" />
              </Style>
            </TreeView.ItemContainerStyle>
          </TreeView>
        </GroupBox>

        <GroupBox Grid.Row="1"
                  Header="Volume"
                  Margin="0,12,0,0"
                  Foreground="{DynamicResource TextBrush}"
                  BorderBrush="{DynamicResource BorderBrush}">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="InputVolumeLabel" Text="Input" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Slider Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    TickFrequency="5"
                    SmallChange="1"
                    LargeChange="5"
                    Value="{Binding InputVolume}"
                    Margin="0,0,0,8"
                    AutomationProperties.LabeledBy="{Binding ElementName=InputVolumeLabel}"
                    AutomationProperties.Name="Microphone input volume" />

            <TextBlock x:Name="OutputVolumeLabel" Grid.Row="1" Text="Output" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Slider Grid.Row="1"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    TickFrequency="5"
                    SmallChange="1"
                    LargeChange="5"
                    Value="{Binding OutputVolume}"
                    AutomationProperties.LabeledBy="{Binding ElementName=OutputVolumeLabel}"
                    AutomationProperties.Name="Speaker output volume" />

            <TextBlock x:Name="VoiceActivationLevelLabel"
                       Grid.Row="2"
                       Text="Voice activation"
                       VerticalAlignment="Center"
                       Margin="0,8,8,0"
                       Visibility="{Binding IsVoiceActivationSliderVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Slider Grid.Row="2"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="100"
                    TickFrequency="1"
                    SmallChange="1"
                    LargeChange="5"
                    Value="{Binding VoiceActivationLevelPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsVoiceActivationSliderVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    AutomationProperties.LabeledBy="{Binding ElementName=VoiceActivationLevelLabel}"
                    AutomationProperties.Name="Voice activation level" />

            <StackPanel Grid.Row="3"
                        Grid.ColumnSpan="2"
                        Margin="0,12,0,0"
                        Visibility="{Binding IsInputMeterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Focusable="False"
                        IsHitTestVisible="False">
              <TextBlock Text="{Binding InputLevelText}"
                         Foreground="{DynamicResource MutedTextBrush}"
                         FontSize="12" />
              <Grid Width="180"
                    Height="12"
                    Margin="0,4,0,0"
                    HorizontalAlignment="Left"
                    ClipToBounds="True">
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" />
                <Rectangle Width="{Binding InputLevelMeterWidth}"
                           HorizontalAlignment="Left"
                           Fill="{DynamicResource AccentBrush}" />
                <Border Width="2"
                        Height="12"
                        HorizontalAlignment="Left"
                        Margin="{Binding VoiceActivationMarkerMargin}"
                        Background="{DynamicResource WarningBrush}" />
              </Grid>
            </StackPanel>
          </Grid>
        </GroupBox>
      </Grid>

      <GridSplitter Grid.Column="1"
                    Width="8"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource SplitterBrush}"
                    AutomationProperties.Name="Resize channel list" />

      <TabControl Grid.Column="2"
                  Background="{DynamicResource WindowBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  AutomationProperties.Name="TeamTalk activity tabs">
        <TabItem Header="Chat">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListView x:Name="ChatHistoryList"
                      ItemsSource="{Binding ChatMessages}"
                      SelectedItem="{Binding SelectedChatMessage, Mode=TwoWay}"
                      KeyDown="ChatHistoryList_OnKeyDown"
                      Visibility="{Binding ChatHistoryListVisibility}"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      AutomationProperties.Name="Channel chat history">
              <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                  <Setter Property="AutomationProperties.HelpText" Value="{Binding AccessibleName}" />
                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
              </ListView.ItemContainerStyle>
              <ListView.ItemTemplate>
                <DataTemplate>
                  <controls:PresentationTextBlock Text="{Binding DisplayText}"
                                                  TextWrapping="Wrap"
                                                  TextTrimming="None"
                                                  Foreground="{DynamicResource TextBrush}" />
                </DataTemplate>
              </ListView.ItemTemplate>
            </ListView>

            <TextBox Text="{Binding ChatHistoryText, Mode=OneWay}"
                     Visibility="{Binding ChatHistoryTextVisibility}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     AutomationProperties.Name="Channel chat history text"
                     AutomationProperties.HelpText="Read-only channel chat transcript" />

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
              <Button DockPanel.Dock="Right"
                      Content="Send"
                      Command="{Binding SendMessageCommand}"
                      MinWidth="92"
                      Margin="8,0,0,0"
                      AutomationProperties.Name="Send channel message" />
              <controls:NativeTextBox x:Name="MessageTextBox"
                                      Text="{Binding MessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SendRequested="MessageTextBox_OnSendRequested"
                                      MinHeight="34"
                                      TextBackground="{DynamicResource ControlBackgroundBrush}"
                                      TextForeground="{DynamicResource TextBrush}"
                                      AutomationProperties.Name="Channel message" />
            </DockPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Video">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="260" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.ColumnSpan="3" Margin="0,0,0,8">
              <Button DockPanel.Dock="Right"
                      Content="{Binding VideoCaptureButtonText}"
                      Command="{Binding ToggleVideoCaptureCommand}"
                      MinWidth="100"
                      Margin="8,0,0,0"
                      AutomationProperties.Name="Start or stop video transmission" />
              <Button DockPanel.Dock="Right"
                      Content="Refresh Cameras"
                      Command="{Binding RefreshVideoDevicesCommand}"
                      MinWidth="120"
                      Margin="8,0,0,0"
                      AutomationProperties.Name="Refresh cameras" />
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Camera"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding VideoCaptureDevices}"
                          SelectedItem="{Binding SelectedVideoCaptureDevice}"
                          DisplayMemberPath="DisplayName"
                          Width="240"
                          IsTextSearchEnabled="True"
                          AutomationProperties.Name="Camera">
                  <ComboBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ComboBoxItem}">
                      <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}" />
                    </Style>
                  </ComboBox.ItemContainerStyle>
                </ComboBox>
                <TextBlock Text="{Binding SelectedVideoCaptureFormatText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{DynamicResource MutedTextBrush}"
                           AutomationProperties.Name="{Binding SelectedVideoCaptureFormatText}" />
              </StackPanel>
            </DockPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding VideoStreams}"
                     SelectedItem="{Binding SelectedVideoStream}"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     AutomationProperties.Name="Active video streams">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MediaStreamViewModel}">
                  <Grid Margin="4">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Resolution}"
                               Foreground="{DynamicResource MutedTextBrush}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Row="1"
                          Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          KeyboardNavigation.TabNavigation="None"
                          AutomationProperties.Name="Resize video preview" />

            <Border Grid.Row="1"
                    Grid.Column="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    AutomationProperties.Name="{Binding VideoPreviewName}">
              <Grid>
                <TextBlock Text="No active video streams"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Visibility="{Binding NoVideoStreamsVisibility}"
                           AutomationProperties.Name="No active video streams" />
                <Image Source="{Binding SelectedVideoStream.Frame}"
                       Stretch="Uniform"
                       Focusable="False"
                       Visibility="{Binding VideoPreviewVisibility}"
                       AutomationProperties.Name="{Binding VideoPreviewName}" />
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Desktops">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="260" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
              <Button Content="Share Desktop"
                      Command="{Binding ShareDesktopCommand}"
                      MinWidth="120"
                      Margin="0,0,8,0"
                      AutomationProperties.Name="Share full desktop" />
              <Button Content="Share Active Window"
                      Command="{Binding ShareActiveWindowCommand}"
                      MinWidth="150"
                      Margin="0,0,8,0"
                      AutomationProperties.Name="Share active window" />
              <Button Content="Stop Sharing"
                      Command="{Binding StopDesktopShareCommand}"
                      MinWidth="110"
                      AutomationProperties.Name="Stop desktop sharing" />
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding DesktopStreams}"
                     SelectedItem="{Binding SelectedDesktopStream}"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     AutomationProperties.Name="Shared desktops">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MediaStreamViewModel}">
                  <Grid Margin="4">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding Resolution}"
                               Foreground="{DynamicResource MutedTextBrush}" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Row="1"
                          Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}"
                          KeyboardNavigation.TabNavigation="None"
                          AutomationProperties.Name="Resize desktop preview" />

            <Border Grid.Row="1"
                    Grid.Column="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    AutomationProperties.Name="{Binding DesktopPreviewName}">
              <Grid>
                <TextBlock Text="No shared desktops"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Visibility="{Binding NoDesktopStreamsVisibility}"
                           AutomationProperties.Name="No shared desktops" />
                <Image Source="{Binding SelectedDesktopStream.Frame}"
                       Stretch="Uniform"
                       Focusable="False"
                       Visibility="{Binding DesktopPreviewVisibility}"
                       AutomationProperties.Name="{Binding DesktopPreviewName}" />
              </Grid>
            </Border>
          </Grid>
        </TabItem>

        <TabItem Header="Files">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="150" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        KeyboardNavigation.TabNavigation="Continue">
              <Button Content="Upload"
                      Command="{Binding UploadFileCommand}"
                      MinWidth="92"
                      Margin="0,0,8,0"
                      AutomationProperties.Name="Upload file to current channel" />
              <Button Content="Download"
                      Command="{Binding DownloadFileCommand}"
                      MinWidth="92"
                      Margin="0,0,8,0"
                      AutomationProperties.Name="Download selected channel file" />
              <Button Content="Delete"
                      Command="{Binding DeleteFileCommand}"
                      MinWidth="92"
                      Margin="0,0,8,0"
                      AutomationProperties.Name="Delete selected channel file" />
              <Button Content="Refresh"
                      Command="{Binding RefreshFilesCommand}"
                      MinWidth="92"
                      AutomationProperties.Name="Refresh channel file list" />
            </StackPanel>

            <ListView Grid.Row="1"
                      Margin="0,10,0,0"
                      ItemsSource="{Binding Files}"
                      SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      AutomationProperties.Name="Channel files">
              <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                </Style>
              </ListView.ItemContainerStyle>
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="300" />
                  <GridViewColumn Header="Size" DisplayMemberBinding="{Binding Size}" Width="110" />
                  <GridViewColumn Header="Owner" DisplayMemberBinding="{Binding Owner}" Width="150" />
                  <GridViewColumn Header="Uploaded" DisplayMemberBinding="{Binding UploadedAt}" Width="180" />
                </GridView>
              </ListView.View>
            </ListView>

            <DockPanel Grid.Row="2" Margin="0,10,0,0">
              <Button DockPanel.Dock="Right"
                      Content="Cancel Transfer"
                      Command="{Binding CancelTransferCommand}"
                      MinWidth="130"
                      AutomationProperties.Name="Cancel selected file transfer" />
              <TextBlock Text="Transfers"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource TextBrush}"
                         AutomationProperties.Name="File transfers" />
            </DockPanel>

            <ListView Grid.Row="3"
                      Margin="0,6,0,0"
                      ItemsSource="{Binding Transfers}"
                      SelectedItem="{Binding SelectedTransfer, Mode=TwoWay}"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      AutomationProperties.Name="File transfer progress">
              <ListView.ItemContainerStyle>
                <Style TargetType="{x:Type ListViewItem}">
                  <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
                </Style>
              </ListView.ItemContainerStyle>
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Direction" DisplayMemberBinding="{Binding Direction}" Width="100" />
                  <GridViewColumn Header="File" DisplayMemberBinding="{Binding RemoteFileName}" Width="260" />
                  <GridViewColumn Header="Progress" DisplayMemberBinding="{Binding ProgressText}" Width="120" />
                  <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusText}" Width="120" />
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>

<Window x:Class="TeamTalkNg.App.JoinChannelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Join Protected Channel"
        Width="460"
        Height="220"
        MinWidth="420"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="140" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=ChannelNameBox}" Content="Channel" />
      <TextBox x:Name="ChannelNameBox"
               Grid.Column="1"
               Text="{Binding ChannelName, Mode=OneWay}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Channel name" />

      <Label Grid.Row="1" Target="{Binding ElementName=PasswordBox}" Content="Password" />
      <PasswordBox x:Name="PasswordBox"
                   Grid.Row="1"
                   Grid.Column="1"
                   PasswordChanged="PasswordBox_OnPasswordChanged"
                   Background="{DynamicResource ControlBackgroundBrush}"
                   Foreground="{DynamicResource TextBrush}"
                   BorderBrush="{DynamicResource BorderBrush}"
                   AutomationProperties.Name="Channel password" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel channel join" />
      <Button DockPanel.Dock="Right"
              Content="Join"
              Command="{Binding JoinCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Join channel" />
    </DockPanel>
  </Grid>
</Window>

<Window x:Class="TeamTalkNg.App.UserAudioSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Audio Settings"
        Width="480"
        Height="260"
        MinWidth="420"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="140" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=UserBox}" Content="User" />
      <TextBox x:Name="UserBox"
               Grid.Column="1"
               Text="{Binding UserName, Mode=OneWay}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Selected user" />

      <Label Grid.Row="1"
             Target="{Binding ElementName=VoiceVolumeSlider}"
             Content="Voice volume"
             Margin="0,12,0,0" />
      <Slider x:Name="VoiceVolumeSlider"
              Grid.Row="1"
              Grid.Column="1"
              Minimum="0"
              Maximum="200"
              TickFrequency="10"
              SmallChange="5"
              LargeChange="10"
              Value="{Binding VoiceVolumePercent}"
              Margin="0,12,0,0"
              AutomationProperties.Name="Selected user voice volume percent"
              AutomationProperties.HelpText="Set to 100 percent for normal volume." />

      <CheckBox Grid.Row="2"
                Grid.Column="1"
                Content="Mute voice"
                IsChecked="{Binding IsVoiceMuted}"
                Margin="0,14,0,0"
                AutomationProperties.Name="Mute selected user's voice" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="OK"
              Command="{Binding OkCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Apply user audio settings" />
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="0,0,8,0"
              AutomationProperties.Name="Cancel user audio settings" />
    </DockPanel>
  </Grid>
</Window>

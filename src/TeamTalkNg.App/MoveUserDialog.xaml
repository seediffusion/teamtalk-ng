<Window x:Class="TeamTalkNg.App.MoveUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move User To Channel"
        Width="560"
        Height="420"
        MinWidth="460"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="130" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=UserNameBox}" Content="User" />
      <TextBox x:Name="UserNameBox"
               Grid.Column="1"
               Text="{Binding UserName}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="User to move" />

      <Label Grid.Row="1" Target="{Binding ElementName=DestinationList}" Content="Destination" />
      <ListBox x:Name="DestinationList"
               Grid.Row="1"
               Grid.Column="1"
               ItemsSource="{Binding Destinations}"
               SelectedItem="{Binding SelectedDestination}"
               DisplayMemberPath="AccessibleName"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Destination channels">
        <ListBox.ItemContainerStyle>
          <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="AutomationProperties.Name" Value="{Binding AccessibleName}" />
          </Style>
        </ListBox.ItemContainerStyle>
      </ListBox>
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel move user" />
      <Button DockPanel.Dock="Right"
              Content="Move"
              Command="{Binding MoveCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Move user to selected channel" />
    </DockPanel>
  </Grid>
</Window>

<Window x:Class="TeamTalkNg.App.ChannelTopicDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Channel Topic"
        Width="520"
        Height="280"
        MinWidth="440"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Target="{Binding ElementName=ChannelNameBox}" Content="Channel" />
      <TextBox x:Name="ChannelNameBox"
               Grid.Column="1"
               Text="{Binding ChannelName}"
               IsReadOnly="True"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Channel name" />

      <Label Grid.Row="1" Target="{Binding ElementName=TopicBox}" Content="Topic" />
      <TextBox x:Name="TopicBox"
               Grid.Row="1"
               Grid.Column="1"
               Text="{Binding Topic, UpdateSourceTrigger=PropertyChanged}"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Background="{DynamicResource ControlBackgroundBrush}"
               Foreground="{DynamicResource TextBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               AutomationProperties.Name="Channel topic" />
    </Grid>

    <DockPanel Grid.Row="1"
               Margin="0,16,0,0"
               LastChildFill="False">
      <Button DockPanel.Dock="Right"
              Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              MinWidth="96"
              Margin="8,0,0,0"
              AutomationProperties.Name="Cancel channel topic edit" />
      <Button DockPanel.Dock="Right"
              Content="Save"
              Command="{Binding SaveCommand}"
              IsDefault="True"
              MinWidth="96"
              AutomationProperties.Name="Save channel topic" />
    </DockPanel>
  </Grid>
</Window>
